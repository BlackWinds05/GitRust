{% extends "pages/repo/layout.jinja" %}
{% block title %}Settings — {{ repo.owner_name }}/{{ repo.name }}{% endblock %}
{% block repo_content %}
<h2>Repository Settings</h2>

<div class="settings-section">
    <h3>Rename</h3>
    <form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/settings/rename">
        <div class="form-group">
            <label for="new_name">New repository name</label>
            <input type="text" id="new_name" name="new_name" class="form-control" value="{{ repo.name }}" required style="max-width:400px;">
        </div>
        <button type="submit" class="btn btn-sm">Rename</button>
    </form>
</div>

<div class="settings-section">
    <h3>General</h3>
    <form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/settings">
        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" class="form-control">{{ repo.description | default("") }}</textarea>
        </div>
        <div class="form-group">
            <label for="default_branch">Default Branch</label>
            <select id="default_branch" name="default_branch" class="form-control" style="max-width:300px;">
                {% for b in branches %}<option value="{{ b }}" {% if b == repo.default_branch %}selected{% endif %}>{{ b }}</option>{% endfor %}
            </select>
        </div>
        <div class="form-group">
            <label for="max_file_size_mb">Max upload file size (MB)</label>
            <input type="number" id="max_file_size_mb" name="max_file_size_mb" class="form-control" value="{{ repo.max_file_size_mb | default(100) }}" style="max-width:150px;">
        </div>
        <div class="form-group">
            <label><input type="checkbox" name="is_private" {% if repo.is_private %}checked{% endif %}> Private repository</label>
        </div>
        <div class="form-group">
            <label><input type="checkbox" name="enable_notifications" {% if repo.enable_notifications | default(true) %}checked{% endif %}> Enable email notifications</label>
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>
</div>

{% if current_user and current_user.id == repo.owner_id %}
<div class="settings-section">
    <h3>Transfer Ownership</h3>
    <p class="text-small mb-4">Transfer this repository to another user.</p>
    <form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/settings/transfer" data-confirm="Transfer ownership? This cannot be undone.">
        <div class="form-group">
            <input type="text" name="new_owner" class="form-control" placeholder="New owner username" required style="max-width:300px;">
        </div>
        <button type="submit" class="btn btn-danger btn-sm">Transfer</button>
    </form>
</div>
{% endif %}

<div class="danger-zone">
    <h3>Danger Zone</h3>
    <p style="font-size:14px;color:var(--color-text-secondary);margin-bottom:12px;">Deleting a repository is permanent and cannot be undone.</p>
    <form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/settings/delete" data-confirm="Permanently delete this repository? This cannot be undone.">
        <button type="submit" class="btn btn-danger">Delete this repository</button>
    </form>
</div>
{% endblock %}
