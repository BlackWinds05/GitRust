{% extends "pages/repo/layout.jinja" %}
{% block title %}Edit Milestone — {{ repo.owner_name }}/{{ repo.name }}{% endblock %}
{% block repo_content %}
<h2>Edit Milestone</h2>
<form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/milestones/{{ milestone.id }}/edit">
    <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" class="form-control" value="{{ milestone.title }}" required>
    </div>
    <div class="form-group">
        <label for="due_date">Due Date</label>
        <input type="date" id="due_date" name="due_date" class="form-control" style="max-width:200px;" value="{% if milestone.due_date %}{{ milestone.due_date }}{% endif %}">
    </div>
    <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" class="form-control" style="min-height:100px;">{{ milestone.description | default('') }}</textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/{{ repo.owner_name }}/{{ repo.name }}/-/milestones" class="btn btn-sm">Cancel</a>
</form>
{% endblock %}
