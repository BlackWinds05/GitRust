{% extends "pages/repo/layout.jinja" %}
{% block title %}New File — {{ repo.owner_name }}/{{ repo.name }}{% endblock %}
{% block repo_content %}
<h2>New File {% if dir_path %}in <code>{{ dir_path }}</code>{% endif %}</h2>
<form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/new-file{% if dir_path %}?path={{ dir_path }}{% endif %}">
    <div class="form-group">
        <label for="file_name">File name</label>
        <input type="text" id="file_name" name="file_name" class="form-control" placeholder="e.g. main.rs" required>
    </div>
    <div class="form-group">
        <label for="branch">Branch</label>
        <select id="branch" name="branch" class="form-control" style="max-width:300px;">
            {% for b in branches %}<option value="{{ b }}" {% if b == default_branch %}selected{% endif %}>{{ b }}</option>{% endfor %}
        </select>
    </div>
    <div class="form-group">
        <label for="content">Content</label>
        <textarea id="content" name="content" class="form-control" style="min-height:300px;font-family:var(--font-mono);font-size:13px;line-height:1.5;"></textarea>
    </div>
    <div class="form-group">
        <label for="commit_message">Commit message</label>
        <input type="text" id="commit_message" name="commit_message" class="form-control" placeholder="Add file" required>
    </div>
    <button type="submit" class="btn btn-primary">Create File</button>
</form>
{% endblock %}
