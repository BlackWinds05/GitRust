{% extends "pages/repo/layout.jinja" %}
{% block title %}Wiki — {{ repo.owner_name }}/{{ repo.name }}{% endblock %}
{% block repo_content %}
<div class="flex-between mb-4">
    <h2>Wiki</h2>
    {% if current_user %}
    <a href="/{{ repo.owner_name }}/{{ repo.name }}/-/wiki/home/edit" class="btn btn-sm btn-primary">New Page</a>
    {% endif %}
</div>
<form method="get" action="/{{ repo.owner_name }}/{{ repo.name }}/-/wiki/search" class="mb-4">
    <input type="text" name="q" class="form-control" placeholder="Search wiki pages..." style="max-width:300px;">
</form>
{% if home_page %}
<div class="wiki-content">{{ home_page.content | safe }}</div>
{% else %}
<div class="empty-state">
    <h3>&#128214; Welcome to the Wiki</h3>
    <p>Document your project knowledge here.</p>
    {% if current_user %}<a href="/{{ repo.owner_name }}/{{ repo.name }}/-/wiki/home/edit" class="btn btn-primary btn-sm mt-2">Create Home Page</a>{% endif %}
</div>
{% endif %}
{% if pages | length > 0 %}
<div style="margin-top:24px;padding-top:16px;border-top:1px solid var(--color-border);">
    <h3 style="font-size:14px;margin-bottom:8px;">All Pages ({{ pages | length }})</h3>
    {% for p in pages %}
    <div><a href="/{{ repo.owner_name }}/{{ repo.name }}/-/wiki/{{ p.slug }}">{{ p.title }}</a> <span class="text-small">v{{ p.revision }}</span></div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
